# Supabase — copy this file to .env.local and fill in your values.
# .env.local is gitignored, so your keys never get committed.
#
# Find these in your Supabase dashboard:
#   Project Settings → API
#   - Project URL        -> VITE_SUPABASE_URL
#   - Project API keys → anon / public  -> VITE_SUPABASE_ANON_KEY
#
# The anon key is safe to expose in the browser; Row Level Security is what
# actually protects your data. NEVER put the service_role key here.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Maps (for Google Places autocomplete in the link editor)
# Get this from Google Cloud Console → APIs & Services → Credentials
# Env var name must match what Lovable injected if you used the connector
VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_BROWSER_KEY=

# App URL — used as the Referer header in server-side Google Places requests.
# This must be whitelisted in Google Cloud Console → your API key → HTTP referrers.
# OR: remove the HTTP referrer restriction entirely (recommended for server-side use).
#
# Set to your deployed Vercel URL or custom domain:
# VITE_APP_URL=https://remix-of-profile-creator-studio.vercel.app
# VITE_APP_URL=https://tapandrate.co.uk
VITE_APP_URL=
